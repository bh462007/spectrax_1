PORT=3001
# CORS_ORIGIN: Comma-separated origins (use * only for local development)
# WARNING: In production, replace * with your actual frontend origin(s)
CORS_ORIGIN=*
SESSION_PATH=./session.json
MAX_SESSION_FRAMES=300
SOCKET_PATH=/socket.io
# SOCKET_AUTH_TOKEN: Shared secret for Socket.IO connections.
# When set, only clients providing this token in handshake.auth.token can connect.
# Leave empty to skip authentication (for local development).
SOCKET_AUTH_TOKEN=
# MAX_CONNECTIONS_PER_IP: Max simultaneous socket connections from a single IP
MAX_CONNECTIONS_PER_IP=10
# MAX_FRAMES_PER_SEC: Max frames per second per connection
MAX_FRAMES_PER_SEC=60
